#include <GL/gl.h>
#include <GL/glut.h>
#include <stdio.h>
#include <math.h>

float x = 0;
float speed = 0.3;
int warna = 0; // 0 = warna berbeda, 1 = warna sama

void init(void) {
    glClearColor(0, 0, 0, 0); // latar belakang putih
    glMatrixMode(GL_PROJECTION);
    gluOrtho2D(0, 50, 0, 50); // bidang 2D yang lebih kecil untuk menyesuaikan ukuran
}

void display(void) {
    glClear(GL_COLOR_BUFFER_BIT);

    // objek 1
    if (warna) {
        glColor3ub(239, 136, 173); // Pink jika warna sama
    } else {
        glColor3ub(255, 0, 0); // Merah jika warna berbeda
    }

    // Gambar hati pertama
    glBegin(GL_POLYGON);
    for (int i = 0; i <= 100; i++) {
        float t = (float)i / 100.0f; // Parameter untuk mengatur sudut
        float angle = t * 2.0f * 3.14159f; // Menghitung sudut
        // Fungsi parametris untuk menggambar hati
        float posisiX = x + 0.25f * (12 * sin(angle) * sin(angle) * sin(angle));
        float posisiY = 15 + 0.25f * (13 * cos(angle) - 5 * cos(2 * angle) - 2 * cos(3 * angle) - cos(4 * angle));

        glVertex2f(posisiX, posisiY); // Menempatkan titik pada posisi yang dihitung
    }
    glEnd();

    // objek 2
    if (warna) {
        glColor3ub(239, 136, 173); // Pink jika warna sama
    } else {
        glColor3ub(255, 255, 255); // Putih jika warna berbeda
    }

    // Gambar hati kedua
    glBegin(GL_POLYGON);
    for (int i = 0; i <= 100; i++) {
        float t = (float)i / 100.0f; // Parameter untuk mengatur sudut
        float angle = t * 2.0f * 3.14159f; // Menghitung sudut
        // Fungsi parametris untuk menggambar hati
        float posisiX = x + 0.25f * (12 * sin(angle) * sin(angle) * sin(angle));
        float posisiY = 35 + 0.25f * (13 * cos(angle) - 5 * cos(2 * angle) - 2 * cos(3 * angle) - cos(4 * angle));

        glVertex2f(posisiX, posisiY); // Menempatkan titik pada posisi yang dihitung
    }
    glEnd();

    glutSwapBuffers();
}

void timer(int a) {
    glutPostRedisplay();
    glutTimerFunc(1000 / 60, timer, 0);
    x += speed;

    if (x >= 50 - 3) { // kanan
        x = 50 - 3;
        speed = -speed;
        warna = 1;
    } else if (x <= 0 + 3) { // kiri
        x = 0 + 3;
        speed = -speed;
        warna = 0;
    }
}


int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(900, 500);
    glutInitWindowPosition(100, 100);
    glutCreateWindow("Tugas1_672022028");

    glutDisplayFunc(display);
    glutTimerFunc(0, timer, 0);
    init();
    glutMainLoop();
    return 0;
}
