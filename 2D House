void mulai() {
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(-500.0, 500.0, -400.0, 400.0);
}

void lerpColor(float r1, float g1, float b1, float r2, float g2, float b2, float t, float& rOut, float& gOut, float& bOut) {
    rOut = r1 + (r2 - r1) * t;
    gOut = g1 + (g2 - g1) * t;
    bOut = b1 + (b2 - b1) * t;
}

void updateWaktu(int value) {
    transitionProgress += 0.005f;
    if (transitionProgress >= 1.0f) {
        transitionProgress = 0.0f;
        waktuSaatIni = static_cast<Waktu>((waktuSaatIni + 1) % 4);
    }

    switch (waktuSaatIni) {
        case SORE:
            lightingFactor = 1.0f - 0.5f * transitionProgress;
            break;
        case MALAM:
            lightingFactor = 0.5f + 0.3f * transitionProgress;
            break;
        case PAGI:
            lightingFactor = 0.8f + 0.2f * transitionProgress;
            break;
        case SIANG:
            lightingFactor = 1.0f;
            break;
    }

    glutPostRedisplay();
    glutTimerFunc(timerInterval, updateWaktu, 0);
}


void drawRectFence(float x1, float y1, float x2, float y2, int boxCount, float boxWidth, float boxHeight) {
    float dx = (x2 - x1) / boxCount;
    float dy = (y2 - y1) / boxCount;
    float totalLength = sqrt((x2 - x1) * (x2 - x1) + (y2 - y1) * (y2 - y1)); // panjang pagar
    for (int i = 0; i < boxCount; i++) {
        float startX = x1 + i * dx;
        float startY = y1 + i * dy;
        // hitung posisi relatif terhadap panjang total (pakai i juga bisa, tapi ini lebih presisi)
        float currentLength = sqrt((startX - x1) * (startX - x1) + (startY - y1) * (startY - y1));
        float t = currentLength / totalLength; // dari 0.0 (kiri) ke 1.0 (kanan)
        // gradasi warna coklat
        float baseR = 0.4f + 0.2f * t; // dari 0.4 ke 0.6
        float baseG = 0.2f + 0.1f * t; // dari 0.2 ke 0.3
        float baseB = 0.05f + 0.05f * t; // dari 0.05 ke 0.1
        glColor3f(baseR* lightingFactor, baseG* lightingFactor, baseB* lightingFactor);
        glBegin(GL_QUADS);
        glVertex2f(startX, startY);
        glVertex2f(startX + boxWidth, startY);
        glVertex2f(startX + boxWidth, startY - boxHeight);
        glVertex2f(startX, startY - boxHeight);
        glEnd();
    }
    glColor3f(1.0f* lightingFactor, 1.0f* lightingFactor, 1.0f* lightingFactor); // reset warna
}

