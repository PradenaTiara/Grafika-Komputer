enum Waktu { SORE, MALAM, PAGI, SIANG };
Waktu waktuSaatIni = SORE;
float transitionProgress = 0.0f;  // 0.0 to 1.0
float lightingFactor = 1.0f;
int timerInterval = 30; // ms


