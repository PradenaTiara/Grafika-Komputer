// fungsi bantu: lingkaran gradasi
void drawCircleGradient(int centerX, int centerY, int radius,
                        float rInner, float gInner, float bInner,
                        float rOuter, float gOuter, float bOuter) {
    int segments = 100;
    glBegin(GL_TRIANGLE_FAN);
        glColor3f(rInner* lightingFactor, gInner* lightingFactor, bInner* lightingFactor);
        glVertex2i(centerX, centerY);
        for (int i = 0; i <= segments; i++) {
            float angle = 2.0f * 3.14159f * i / segments;
            float x = centerX + cos(angle) * radius;
            float y = centerY + sin(angle) * radius;
            glColor3f(rOuter* lightingFactor, gOuter* lightingFactor, bOuter* lightingFactor);
            glVertex2i((int)x, (int)y);
        }
    glEnd();
}

