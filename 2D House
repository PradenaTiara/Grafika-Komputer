void getSunPosition(float& x, float& y) {
    float totalT = 0.0f;

    if (waktuSaatIni == PAGI) {
        totalT = transitionProgress / 3.0f; // 0.0 - 1/3
    } else if (waktuSaatIni == SIANG) {
        totalT = (1.0f / 3.0f) + (transitionProgress / 3.0f); // 1/3 - 2/3
    } else if (waktuSaatIni == SORE) {
        totalT = (2.0f / 3.0f) + (transitionProgress / 3.0f); // 2/3 - 1.0
    } else {
        totalT = 1.0f; // malam: matahari sudah tidak terlihat
    }

    if (totalT > 1.0f) totalT = 1.0f;

    // Matahari bergerak setengah lingkaran dari kiri ke kanan (x: -400 → +400)
    float angle = totalT * M_PI; // 0 → π

    x = -400.0f * cos(angle);                 // dari -400 ke +400
    y = 200.0f * sin(angle) + 250.0f;         // dari 250 ke 450 (puncak di siang hari)

    // Saat malam atau sudah terlalu rendah, sembunyikan matahari
    if (waktuSaatIni == MALAM || y < 150.0f) {
        y = -999.0f; // Tidak digambar
    }
}



void getMoonPosition(float& x, float& y) {
    float angle = transitionProgress * M_PI; // 0 to π
    float radius = 400.0f;
    x = -400.0f * cos(angle);     // dari +400 ke -400
    y = 200.0f * sin(angle) + 250.0f;
}

void drawSun() {
    float cx, cy;
    getSunPosition(cx, cy);

    if (cy < 0) return; // tidak digambar jika disembunyikan

    glColor3f(1.0f * lightingFactor, 1.0f * lightingFactor, 0.0f);
    float radius = 30;
    glBegin(GL_TRIANGLE_FAN);
    glVertex2f(cx, cy);
    for (int i = 0; i <= 100; i++) {
        float angle = i * 2.0f * M_PI / 100;
        glVertex2f(cx + cos(angle) * radius, cy + sin(angle) * radius);
    }
    glEnd();
}

void drawMoon() {
    float cx, cy;
    getMoonPosition(cx, cy);
    float radius = 25;

    glColor3f(1.0f, 1.0f, 0.8f); // warna kuning pucat
    glBegin(GL_TRIANGLE_FAN);
    glVertex2f(cx, cy);
    for (int i = 0; i <= 100; i++) {
        float angle = i * 2.0f * M_PI / 100;
        glVertex2f(cx + cos(angle) * radius, cy + sin(angle) * radius);
    }
    glEnd();
}

